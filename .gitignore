# ===== Go =====
# Dev build binaries (Wails output lives in build/bin, covered below)
/f9
/cmd/f9/f9
# Test / coverage / profiling output
*.test
*.out
coverage.*
# Go workspace files (personal, multi-module dev)
go.work
go.work.sum

# ===== Wails build output =====
# Only the built binaries; the rest of build/ (appicon, Info.plist, manifests)
# is project config and stays tracked.
/build/bin/

# ===== Frontend (Node / Vite) =====
frontend/node_modules/
frontend/.vite/
frontend/*.local
# NOTE: frontend/dist/ is intentionally committed — Wails go:embed needs it for
# a bare `go build`. Do NOT ignore it.

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== Editors / IDEs =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== OS cruft =====
.DS_Store
Thumbs.db
Desktop.ini

# ===== Env / secrets =====
.env
.env.*
